# Copy to .env and fill in values before running docker compose

# Postgres
POSTGRES_DB=cpcx
POSTGRES_USER=cpcx
POSTGRES_PASSWORD=changeme          # required — no default
POSTGRES_DATA_PATH=~/postgres       # host path for postgres data volume

# cpcx app
CPCX_PROJECT_PATH=cpcx              # path to the .csproj dir, relative to repo root
