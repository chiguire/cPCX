@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-9">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>Create a new account</h2>
            <hr />
            <p>You can set an email after creating the account</p>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="row mb-3 align-items-start">
                <div class="col-7">
                    <div class="form-floating">
                        <input asp-for="Input.Username" class="form-control" autocomplete="username" aria-required="true" placeholder="username" id="usernameInput" />
                        <label asp-for="Input.Username">Username</label>
                        <span asp-validation-for="Input.Username" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-5 pt-2">
                    <ul class="list-unstyled small mb-1 emoji">
                        <li id="req-username-min" class="text-danger"><span class="req-icon">❌</span> At least 3 characters</li>
                        <li id="req-username-max" class="text-danger"><span class="req-icon">❌</span> At most 40 characters</li>
                        <li id="req-username-chars" class="text-danger"><span class="req-icon">❌</span> Letters, digits, '.', '_', or '-' only</li>
                        <li id="usernameAvailability" class=""><span class="req-icon"></span> <span class="req-text"></span></li>
                    </ul>
                </div>
            </div>

            <div class="row mb-3 align-items-start">
                <div class="col-7">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" id="passwordInput" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-floating">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" id="confirmPasswordInput" />
                        <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-5 pt-2">
                    <ul class="list-unstyled small mb-0 emoji">
                        <li id="req-length" class="text-danger"><span class="req-icon">❌</span> At least 6 characters</li>
                        <li id="req-upper" class="text-danger"><span class="req-icon">❌</span> At least one uppercase letter (A–Z)</li>
                        <li id="req-lower" class="text-danger"><span class="req-icon">❌</span> At least one lowercase letter (a–z)</li>
                        <li id="req-digit" class="text-danger"><span class="req-icon">❌</span> At least one digit (0–9)</li>
                        <li id="req-special" class="text-danger"><span class="req-icon">❌</span> At least one special character</li>
                        <li id="req-match" class="text-danger"><span class="req-icon">❌</span> Passwords match</li>
                    </ul>
                </div>
            </div>

            <div class="row">
                <div class="col-7">
                    <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary" disabled>Register</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function setReq(id, met) {
                const li = document.getElementById(id);
                const icon = li.querySelector('.req-icon');
                icon.textContent = met ? '\u2705' : '\u274c';
                twemoji.parse(icon, { folder: 'svg', ext: '.svg' });
                li.className = met ? 'text-success' : 'text-danger';
            }

            function setAvailability(emoji, text, cssClass) {
                const li = document.getElementById('usernameAvailability');
                const icon = li.querySelector('.req-icon');
                icon.textContent = emoji;
                if (emoji) twemoji.parse(icon, { folder: 'svg', ext: '.svg' });
                li.querySelector('.req-text').textContent = text;
                li.className = cssClass;
            }

            const submitBtn = document.getElementById('registerSubmit');
            const state = { username: false, available: false, password: false };

            function updateSubmitButton() {
                submitBtn.disabled = !(state.username && state.available && state.password);
            }

            // Username requirements
            const usernameInput = document.getElementById('usernameInput');
            let debounceTimer;

            const usernameChecks = {
                'req-username-min':   v => v.length >= 3,
                'req-username-max':   v => v.length <= 40,
                'req-username-chars': v => /^[a-zA-Z0-9._-]*$/.test(v),
            };

            usernameInput.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                setAvailability('', '', '');
                state.available = false;

                const username = usernameInput.value.trim();

                state.username = Object.values(usernameChecks).every(check => check(username));
                for (const [id, check] of Object.entries(usernameChecks)) {
                    setReq(id, check(username));
                }
                updateSubmitButton();

                if (username.length < 3) return;

                setAvailability('\u23f3', 'Checking if username is available\u2026', 'text-muted');

                debounceTimer = setTimeout(async function () {
                    try {
                        const response = await fetch('/api/Register/CheckUserAlias', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(username)
                        });
                        const isAvailable = await response.json();
                        if (isAvailable) {
                            setAvailability('\u2705', 'Username is available.', 'text-success');
                        } else {
                            setAvailability('\u274c', 'Username is already taken.', 'text-danger');
                        }
                        state.available = isAvailable;
                        updateSubmitButton();
                    } catch {
                        setAvailability('', '', '');
                    }
                }, 200);
            });

            // Password requirements
            const passwordInput = document.getElementById('passwordInput');
            const confirmPasswordInput = document.getElementById('confirmPasswordInput');
            const passwordChecks = {
                'req-length':  v => v.length >= 6,
                'req-upper':   v => /[A-Z]/.test(v),
                'req-lower':   v => /[a-z]/.test(v),
                'req-digit':   v => /[0-9]/.test(v),
                'req-special': v => /[^a-zA-Z0-9]/.test(v),
            };

            function updatePasswordRequirements() {
                const value = passwordInput.value;
                const match = value.length > 0 && value === confirmPasswordInput.value;
                for (const [id, check] of Object.entries(passwordChecks)) {
                    setReq(id, check(value));
                }
                setReq('req-match', match);
                state.password = Object.values(passwordChecks).every(check => check(value)) && match;
                updateSubmitButton();
            }

            passwordInput.addEventListener('input', updatePasswordRequirements);
            confirmPasswordInput.addEventListener('input', updatePasswordRequirements);

            // Parse initial ❌ icons via twemoji
            document.querySelectorAll('.req-icon').forEach(el => {
                twemoji.parse(el, { folder: 'svg', ext: '.svg' });
            });
        })();
    </script>
}
