@page
@model BlockedUsersModel
@{
    ViewData["Title"] = "Blocked Users";
    ViewData["ActivePage"] = ManageNavPages.BlockedUsers;
}

<h3>@ViewData["Title"]</h3>

@if (Model.BlockedUsers.Count == 0)
{
    <p class="text-muted">You have not blocked anyone.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Username</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.BlockedUsers)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>
                        <form method="post" asp-page-handler="Unblock">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Unblock</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
