@page
@model cpcx.Pages.RestrictedModel

@{
    ViewData["Title"] = "Access Restricted";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DeerPost.cx</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="text-center" style="max-width: 520px;">
        <h1 class="display-4 fw-bold mb-4">DeerPost.cx</h1>

        @if (Model.IsDeactivated)
        {
            <div class="alert alert-warning">
                <p class="mb-0">Your account has been deactivated.</p>
            </div>
        }
        else if (Model.IsBlocked)
        {
            <div class="alert alert-warning">
                <p class="mb-0">
                    Your account has been temporarily suspended.
                    @if (Model.BlockedUntil.HasValue)
                    {
                        <span>Access will be restored on @Model.BlockedUntil.Value.ToString("f", System.Globalization.CultureInfo.CreateSpecificCulture("en-GB")) UTC.</span>
                    }
                </p>
            </div>
        }

        <p>
            Please contact the event caretaker at
            <a href="mailto:@Model.CaretakerEmail">@Model.CaretakerEmail</a>
            if you believe this is a mistake.
        </p>

        <form method="post" asp-page-handler="SignOut">
            <button type="submit" class="btn btn-outline-secondary">Sign out</button>
        </form>
    </div>
</body>
</html>