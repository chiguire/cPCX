@page
@model cpcx.Pages.Onboarding.Index
@{
    ViewData["Title"] = "Welcome to DeerPost";
    string[] stepNames = ["Your Profile", "Your Address", "Your Avatar", "Your Email"];
}

<h1>@ViewData["Title"]</h1>
<partial name="_StatusMessage" model="Model.StatusMessage" />

<p class="text-muted mb-4">Step @Model.Step of 4 — @stepNames[Model.Step - 1]</p>

@if (Model.Step == 1)
{
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <input type="hidden" asp-for="Step" value="1" />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <select asp-for="Profile.Pronoun" asp-items="@Model.Pronouns" class="form-select"></select>
                    <label asp-for="Profile.Pronoun" class="form-label"></label>
                </div>
                <div class="form-floating mb-3">
                    <textarea asp-for="Profile.ProfileDescription" class="form-control" style="height: 100px" id="profileDescInput"></textarea>
                    <label asp-for="Profile.ProfileDescription" class="form-label"></label>
                    <span asp-validation-for="Profile.ProfileDescription" class="text-danger"></span>
                </div>
                <div class="position-relative mb-3">
                    &nbsp;
                    <div id="ProfileLengthDisplay" class="position-absolute top-0 end-0 text-muted small">0/3000</div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save &amp; Continue</button>
                    <button type="submit" name="Skip" value="true" class="btn btn-outline-secondary">Skip</button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            function updateLength() {
                const m = $("#Profile_ProfileDescription");
                $("#ProfileLengthDisplay").text(m.val().length + "/3000");
            }
            $().ready(function () { updateLength(); });
            $("#Profile_ProfileDescription").on("input", function () { updateLength(); });
        </script>
    }
}

@if (Model.Step == 2)
{
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <input type="hidden" asp-for="Step" value="2" />
                <div class="form-floating mb-3">
                    <textarea asp-for="Address.AddressInEvent" class="form-control" id="addressInput" style="height: 100px"
                              aria-describedby="address-description"></textarea>
                    <label asp-for="Address.AddressInEvent" class="form-label"></label>
                    <span id="address-description" class="form-text text-muted">Be as specific as necessary. Look out for <a href="https://wiki.emfcamp.org/2024/wiki/Sneakernet">experimental postcodes</a> if that helps.</span>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="Address.UserActiveInEvent" class="form-check-input" id="activeCheckbox" />
                    <label asp-for="Address.UserActiveInEvent" class="form-check-label"></label>
                    <div class="form-text text-muted">Uncheck to mark yourself away — you will not receive new postcards.</div>
                </div>
                <span asp-validation-for="Address.AddressInEvent" class="text-danger d-block mb-2" id="addressValidation"></span>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save &amp; Continue</button>
                    <button type="submit" name="Skip" value="true" class="btn btn-outline-secondary">Skip</button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            (function () {
                const address = document.getElementById('addressInput');
                const active = document.getElementById('activeCheckbox');
                const addressError = document.getElementById('addressValidation');
                const addressStartedEmpty = address.value.trim() === '';

                address.addEventListener('input', function () {
                    if (addressStartedEmpty && address.value.trim() !== '') active.checked = true;
                    if (address.value.trim() !== '') addressError.textContent = '';
                });

                active.addEventListener('change', function () {
                    if (active.checked && address.value.trim() === '') {
                        addressError.textContent = 'Address is required when active in event.';
                        active.checked = false;
                    }
                });

                document.querySelector('form').addEventListener('submit', function (e) {
                    const isSkip = document.activeElement && document.activeElement.name === 'Skip';
                    if (!isSkip && active.checked && address.value.trim() === '') {
                        addressError.textContent = 'Address is required when active in event.';
                        e.preventDefault();
                    }
                });
            })();
        </script>
    }
}

@if (Model.Step == 3)
{
    <form method="post">
        <input type="hidden" asp-for="Step" value="3" />
        <input type="hidden" id="SelectedAvatar" name="Avatar.SelectedAvatar" value="@Model.Avatar.SelectedAvatar" />
        <div class="row row-cols-3 row-cols-md-6 g-3 mb-3">
            @foreach (var avatar in Model.Avatars)
            {
                var isSelected = avatar == Model.Avatar.SelectedAvatar;
                <div class="col">
                    <div class="avatar-option @(isSelected ? "avatar-selected" : "")"
                         data-avatar="@avatar"
                         role="button"
                         title="@System.IO.Path.GetFileNameWithoutExtension(avatar)">
                        <img src="/zooka/avatars/@Uri.EscapeDataString(avatar)"
                             class="img-fluid rounded"
                             alt="@System.IO.Path.GetFileNameWithoutExtension(avatar)" />
                    </div>
                </div>
            }
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save &amp; Continue</button>
            <button type="submit" name="Skip" value="true" class="btn btn-outline-secondary">Skip</button>
        </div>
    </form>

    @section Scripts {
        <script>
            document.querySelectorAll('.avatar-option').forEach(function (el) {
                el.addEventListener('click', function () {
                    document.querySelectorAll('.avatar-option').forEach(function (e) {
                        e.classList.remove('avatar-selected');
                    });
                    this.classList.add('avatar-selected');
                    document.getElementById('SelectedAvatar').value = this.dataset.avatar;
                });
            });
        </script>
    }
}

@if (Model.Step == 4)
{
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <input type="hidden" asp-for="Step" value="4" />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="EmailStep.Email" type="email" class="form-control"
                           placeholder="your@email.com"
                           aria-describedby="email-description" />
                    <label asp-for="EmailStep.Email" class="form-label"></label>
                    <span asp-validation-for="EmailStep.Email" class="text-danger"></span>
                </div>
                <p id="email-description" class="text-muted small mb-3">Your email is optional. If provided, a confirmation link will be sent to verify it.</p>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Finish</button>
                    <button type="submit" name="Skip" value="true" class="btn btn-outline-secondary">Skip</button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
}
